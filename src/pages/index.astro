---
import '../styles/global.css';
import en from '../i18n/en.json';
import de from '../i18n/de.json';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="LemonSpace — The visual AI workspace for creative teams. Generate campaign-ready image variants at scale with a node-based canvas." />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <title>LemonSpace — Your Visual AI Workspace</title>

    <!-- Theme init (blocking — prevents flash of wrong theme) -->
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>

    <style>
      /* Logo visibility based on theme */
      .logo-light { display: inline-block; }
      .logo-dark { display: none; }
      [data-theme="dark"] .logo-light { display: none; }
      [data-theme="dark"] .logo-dark { display: inline-block; }

      /* Shadow adjustment for light mode */
      .hero-card-shadow {
        box-shadow: 0 25px 50px -12px rgba(28, 25, 23, 0.12);
      }
      [data-theme="dark"] .hero-card-shadow {
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);
      }
    </style>
  </head>

  <body class="bg-surface-1 text-text-primary font-sans overflow-x-hidden">

    <!-- ===== NAVIGATION ===== -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-surface-1/80 backdrop-blur-xl border-b border-border/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a href="#" class="flex items-center gap-2 shrink-0">
            <img
              src="/logos/lemonspace-logo-v2-primary-rgb.svg"
              alt="LemonSpace"
              class="h-8 w-auto logo-light"
            />
            <img
              src="/logos/lemonspace-logo-v2-white-rgb.svg"
              alt="LemonSpace"
              class="h-8 w-auto logo-dark"
            />
          </a>

          <!-- Desktop Nav Links -->
          <div class="hidden md:flex items-center gap-8">
            <a href="#features" data-i18n="nav.features" class="text-sm text-text-secondary hover:text-text-primary transition-colors">Features</a>
            <a href="#how-it-works" data-i18n="nav.howItWorks" class="text-sm text-text-secondary hover:text-text-primary transition-colors">How it Works</a>
            <a href="#pricing" data-i18n="nav.pricing" class="text-sm text-text-secondary hover:text-text-primary transition-colors">Pricing</a>
          </div>

          <!-- Desktop Controls: Theme + Lang + CTA -->
          <div class="hidden md:flex items-center gap-3">
            <!-- Theme Toggle -->
            <button
              id="theme-toggle"
              type="button"
              aria-label="Toggle theme"
              class="p-2 rounded-lg text-text-secondary hover:text-text-primary hover:bg-surface-3 transition-colors"
            >
              <!-- Moon icon (shown in light mode to switch to dark) -->
              <svg class="w-5 h-5 theme-icon-moon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
              </svg>
              <!-- Sun icon (shown in dark mode to switch to light) -->
              <svg class="w-5 h-5 theme-icon-sun hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </button>

            <!-- Language Switcher -->
            <div class="flex items-center gap-1 text-sm">
              <button data-lang="de" class="lang-btn px-1.5 py-0.5 rounded transition-colors text-text-tertiary hover:text-text-primary">DE</button>
              <span class="text-text-tertiary">|</span>
              <button data-lang="en" class="lang-btn px-1.5 py-0.5 rounded transition-colors font-semibold text-text-primary">EN</button>
            </div>

            <!-- CTA -->
            <a
              href="#pricing"
              data-i18n="nav.getStarted"
              class="inline-flex items-center justify-center px-4 py-2 text-sm font-semibold rounded-lg bg-primary text-white hover:bg-primary-light transition-colors"
            >
              Get Started Free
            </a>
          </div>

          <!-- Mobile Menu Toggle -->
          <div class="md:hidden flex items-center gap-2">
            <!-- Mobile theme toggle -->
            <button
              id="theme-toggle-mobile"
              type="button"
              aria-label="Toggle theme"
              class="p-2 rounded-lg text-text-secondary hover:text-text-primary hover:bg-surface-3 transition-colors"
            >
              <svg class="w-5 h-5 theme-icon-moon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
              </svg>
              <svg class="w-5 h-5 theme-icon-sun hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </button>

            <!-- Hamburger -->
            <label for="mobile-menu-toggle" class="flex flex-col justify-center items-center w-10 h-10 cursor-pointer gap-1.5">
              <span class="block w-5 h-0.5 bg-text-secondary transition-all"></span>
              <span class="block w-5 h-0.5 bg-text-secondary transition-all"></span>
              <span class="block w-5 h-0.5 bg-text-secondary transition-all"></span>
            </label>
          </div>

          <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />

          <!-- Mobile Menu -->
          <div class="hidden peer-checked:flex absolute top-16 left-0 right-0 bg-surface-1/95 backdrop-blur-xl border-b border-border md:hidden flex-col p-6 gap-4">
            <a href="#features" data-i18n="nav.features" class="text-sm text-text-secondary hover:text-text-primary transition-colors py-2">Features</a>
            <a href="#how-it-works" data-i18n="nav.howItWorks" class="text-sm text-text-secondary hover:text-text-primary transition-colors py-2">How it Works</a>
            <a href="#pricing" data-i18n="nav.pricing" class="text-sm text-text-secondary hover:text-text-primary transition-colors py-2">Pricing</a>

            <!-- Mobile language switcher -->
            <div class="flex items-center gap-2 py-2 text-sm">
              <button data-lang="de" class="lang-btn px-2 py-1 rounded transition-colors text-text-tertiary hover:text-text-primary">DE</button>
              <span class="text-text-tertiary">|</span>
              <button data-lang="en" class="lang-btn px-2 py-1 rounded transition-colors font-semibold text-text-primary">EN</button>
            </div>

            <a
              href="#pricing"
              data-i18n="nav.getStarted"
              class="inline-flex items-center justify-center px-4 py-2.5 text-sm font-semibold rounded-lg bg-primary text-white hover:bg-primary-light transition-colors mt-2"
            >
              Get Started Free
            </a>
          </div>
        </div>
      </div>
    </nav>

    <!-- ===== HERO SECTION ===== -->
    <section class="relative pt-32 pb-20 sm:pt-40 sm:pb-28 lg:pt-48 lg:pb-36 overflow-hidden">
      <!-- Background glow effects -->
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary/8 rounded-full blur-[120px]"></div>
        <div class="absolute top-1/3 right-0 w-[400px] h-[400px] bg-accent/5 rounded-full blur-[100px]"></div>
      </div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto text-center">
          <!-- Badge -->
          <div class="animate-fade-in inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/10 border border-primary/20 text-primary-light text-sm font-medium mb-8">
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-primary animate-pulse-glow"></span>
            <span data-i18n="hero.badge">50 Credits Free — No Credit Card Required</span>
          </div>

          <!-- Headline -->
          <h1 class="animate-fade-in-up text-4xl sm:text-5xl lg:text-7xl font-extrabold tracking-tight leading-[1.1] mb-6">
            <span data-i18n="hero.headlinePrefix">Your Visual</span><span class="text-primary" data-i18n="hero.headlineAccent"> AI Workspace</span>
          </h1>

          <!-- Subheadline -->
          <p class="animate-fade-in-up text-lg sm:text-xl lg:text-2xl text-text-secondary max-w-2xl mx-auto mb-10 leading-relaxed" style="animation-delay: 0.15s" data-i18n="hero.subheadline">
            Node-based canvas for creative teams to generate, compare, and export campaign-ready image variants at scale.
          </p>

          <!-- CTA Buttons -->
          <div class="animate-fade-in-up flex flex-col sm:flex-row items-center justify-center gap-4 mb-16" style="animation-delay: 0.3s">
            <a
              href="#pricing"
              class="inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold rounded-xl bg-primary text-white hover:bg-primary-light transition-all shadow-lg shadow-primary/25 hover:shadow-primary/40 hover:-translate-y-0.5"
            >
              <span data-i18n="hero.ctaPrimary">Get Started Free</span>
              <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </a>
            <a
              href="#how-it-works"
              class="inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold rounded-xl bg-surface-3 text-text-primary border border-border hover:border-border-light hover:bg-surface-4 transition-all"
            >
              <span data-i18n="hero.ctaSecondary">See How it Works</span>
            </a>
          </div>

          <!-- Hero Visual: Stylized node graph -->
          <div class="animate-fade-in relative max-w-3xl mx-auto" style="animation-delay: 0.45s">
            <div class="relative rounded-2xl border border-border bg-surface-2/80 backdrop-blur-sm p-6 sm:p-8 hero-card-shadow">
              <!-- Decorative top bar -->
              <div class="flex items-center gap-2 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500/60"></div>
                <div class="w-3 h-3 rounded-full bg-green-500/60"></div>
                <span class="ml-3 text-xs text-text-tertiary font-mono" data-i18n="hero.canvasFilename">workflow-01.lemon</span>
              </div>

              <!-- Node graph illustration -->
              <div class="grid grid-cols-3 gap-4 sm:gap-6">
                <!-- Node 1: Input Image -->
                <div class="group rounded-xl border border-border bg-surface-3 p-3 sm:p-4 hover:border-primary/40 transition-colors">
                  <div class="w-full aspect-[4/3] rounded-lg bg-gradient-to-br from-primary/20 to-accent/10 mb-3 flex items-center justify-center">
                    <svg class="w-8 h-8 sm:w-10 sm:h-10 text-primary/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" /></svg>
                  </div>
                  <div class="text-xs sm:text-sm font-semibold text-text-primary" data-i18n="hero.node1Title">Image</div>
                  <div class="text-[10px] sm:text-xs text-text-tertiary mt-0.5" data-i18n="hero.node1Subtitle">input.jpg</div>
                </div>

                <!-- Node 2: Prompt -->
                <div class="group rounded-xl border border-border bg-surface-3 p-3 sm:p-4 hover:border-accent/40 transition-colors">
                  <div class="w-full aspect-[4/3] rounded-lg bg-gradient-to-br from-accent/15 to-accent-warm/10 mb-3 flex items-center justify-center">
                    <svg class="w-8 h-8 sm:w-10 sm:h-10 text-accent/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" /></svg>
                  </div>
                  <div class="text-xs sm:text-sm font-semibold text-text-primary" data-i18n="hero.node2Title">Prompt</div>
                  <div class="text-[10px] sm:text-xs text-text-tertiary mt-0.5" data-i18n="hero.node2Subtitle">"Summer campaign..."</div>
                </div>

                <!-- Node 3: AI Output -->
                <div class="group rounded-xl border border-primary/30 bg-primary/5 p-3 sm:p-4 hover:border-primary/50 transition-colors">
                  <div class="w-full aspect-[4/3] rounded-lg bg-gradient-to-br from-primary/20 via-accent/10 to-primary/15 mb-3 flex items-center justify-center relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-t from-primary/10 to-transparent"></div>
                    <svg class="w-8 h-8 sm:w-10 sm:h-10 text-primary/70 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>
                  </div>
                  <div class="text-xs sm:text-sm font-semibold text-primary-light" data-i18n="hero.node3Title">AI Image</div>
                  <div class="text-[10px] sm:text-xs text-text-tertiary mt-0.5" data-i18n="hero.node3Subtitle">FLUX.2 → output</div>
                </div>
              </div>

              <!-- Connection lines (decorative) -->
              <div class="hidden sm:flex absolute top-1/2 left-[33.3%] w-[calc(33.3%-1rem)] -translate-y-8 border-t border-dashed border-primary/30 pointer-events-none" aria-hidden="true"></div>
              <div class="hidden sm:flex absolute top-1/2 left-[66.6%] w-[calc(33.3%-1rem)] -translate-y-8 border-t border-dashed border-primary/30 pointer-events-none" aria-hidden="true"></div>

              <!-- Bottom status -->
              <div class="flex items-center justify-between mt-6 pt-4 border-t border-border">
                <div class="flex items-center gap-2">
                  <span class="inline-block w-2 h-2 rounded-full bg-primary animate-pulse"></span>
                  <span class="text-xs text-text-tertiary" data-i18n="hero.statusNodes">3 nodes connected</span>
                </div>
                <span class="text-xs text-text-tertiary font-mono" data-i18n="hero.statusReady">Ready to generate</span>
              </div>
            </div>

            <!-- Decorative glow behind the card -->
            <div class="absolute -inset-4 bg-gradient-to-r from-primary/10 via-accent/5 to-primary/10 rounded-3xl blur-2xl -z-10" aria-hidden="true"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== FEATURES SECTION ===== -->
    <section id="features" class="relative py-20 sm:py-28 lg:py-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Section Header -->
        <div class="max-w-2xl mx-auto text-center mb-16 sm:mb-20">
          <p class="text-sm font-semibold text-primary uppercase tracking-widest mb-3" data-i18n="features.label">Features</p>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-5" data-i18n="features.headline">
            Everything you need for visual AI workflows
          </h2>
          <p class="text-lg text-text-secondary" data-i18n="features.subheadline">
            A powerful node-based canvas with built-in AI models, smart agents, and everything your creative team needs to produce stunning image variants.
          </p>
        </div>

        <!-- Feature Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
          <!-- Feature 1: Node-Based Canvas -->
          <div class="group relative rounded-2xl border border-border bg-surface-2/60 p-6 hover:border-primary/30 hover:bg-surface-2 transition-all duration-300">
            <div class="w-11 h-11 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center mb-5 group-hover:bg-primary/15 transition-colors">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
            </div>
            <h3 class="text-base font-semibold text-text-primary mb-2" data-i18n="features.canvas.title">Node-Based Canvas</h3>
            <p class="text-sm text-text-secondary leading-relaxed" data-i18n="features.canvas.desc">
              Drag-and-drop visual editor. Connect Image, Text, Prompt, and AI Image nodes to build custom AI workflows. No code needed.
            </p>
          </div>

          <!-- Feature 2: 9+ AI Models -->
          <div class="group relative rounded-2xl border border-border bg-surface-2/60 p-6 hover:border-primary/30 hover:bg-surface-2 transition-all duration-300">
            <div class="w-11 h-11 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center mb-5 group-hover:bg-primary/15 transition-colors">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>
            </div>
            <h3 class="text-base font-semibold text-text-primary mb-2" data-i18n="features.models.title">9+ AI Models</h3>
            <p class="text-sm text-text-secondary leading-relaxed" data-i18n="features.models.desc">
              Access FLUX.2, Gemini, GPT-5 Image and more through OpenRouter. Pick the perfect model for every task.
            </p>
          </div>

          <!-- Feature 3: Smart Agents -->
          <div class="group relative rounded-2xl border border-border bg-surface-2/60 p-6 hover:border-primary/30 hover:bg-surface-2 transition-all duration-300">
            <div class="w-11 h-11 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center mb-5 group-hover:bg-accent/15 transition-colors">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>
            </div>
            <h3 class="text-base font-semibold text-text-primary mb-2" data-i18n="features.agents.title">Smart Agents</h3>
            <p class="text-sm text-text-secondary leading-relaxed" data-i18n="features.agents.desc">
              Automate batch operations with intelligent agents that analyze, plan, and execute across multiple nodes. Like having an AI assistant on your canvas.
            </p>
          </div>

          <!-- Feature 4: Visual Compare -->
          <div class="group relative rounded-2xl border border-border bg-surface-2/60 p-6 hover:border-primary/30 hover:bg-surface-2 transition-all duration-300">
            <div class="w-11 h-11 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center mb-5 group-hover:bg-primary/15 transition-colors">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>
            </div>
            <h3 class="text-base font-semibold text-text-primary mb-2" data-i18n="features.compare.title">Visual Compare</h3>
            <p class="text-sm text-text-secondary leading-relaxed" data-i18n="features.compare.desc">
              Side-by-side comparison of generated variants. Pick the best output instantly.
            </p>
          </div>

          <!-- Feature 5: One-Click Export -->
          <div class="group relative rounded-2xl border border-border bg-surface-2/60 p-6 hover:border-primary/30 hover:bg-surface-2 transition-all duration-300">
            <div class="w-11 h-11 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center mb-5 group-hover:bg-primary/15 transition-colors">
