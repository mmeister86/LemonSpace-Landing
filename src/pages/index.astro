---
import '../styles/global.css';
import en from '../i18n/en.json';
import de from '../i18n/de.json';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={en.meta.description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>LemonSpace — Your Visual AI Workspace</title>

    <!-- Theme init (blocking — prevents flash of wrong theme) -->
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>

    <script
    src="https://rybbit.matthias.lol/api/script.js"
    data-site-id="4eccaa2ec1ec"
    defer
></script>

    <style>
      .logo-light { display: inline-block; }
      .logo-dark { display: none; }
      [data-theme="dark"] .logo-light { display: none; }
      [data-theme="dark"] .logo-dark { display: inline-block; }
    </style>

  </head>

  <body class="bg-surface-2 text-text-primary font-sans overflow-x-hidden">

    <!-- ===== NAVIGATION ===== -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-surface-2/80 backdrop-blur-xl border-b border-border/60">
      <div class="max-w-6xl mx-auto px-5 sm:px-6">
        <div class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a href="#" class="flex items-center gap-2 shrink-0">
            <img src="/logos/lemonspace-logo-v2-primary-rgb.svg" alt="LemonSpace" class="h-7 w-auto logo-light" />
            <img src="/logos/lemonspace-logo-v2-white-rgb.svg" alt="LemonSpace" class="h-7 w-auto logo-dark" />
          </a>

          <!-- Desktop Nav -->
          <div class="hidden md:flex items-center gap-7">
            <a href="#features" data-i18n="nav.features" class="text-sm text-text-secondary hover:text-text-primary transition-colors">Features</a>
            <a href="#how-it-works" data-i18n="nav.howItWorks" class="text-sm text-text-secondary hover:text-text-primary transition-colors">How it Works</a>
            <a href="#pricing" data-i18n="nav.pricing" class="text-sm text-text-secondary hover:text-text-primary transition-colors">Pricing</a>
          </div>

          <!-- Desktop Controls -->
          <div class="hidden md:flex items-center gap-3">
            <button id="theme-toggle" type="button" aria-label="Toggle theme" class="p-2 rounded-lg text-text-secondary hover:text-text-primary hover:bg-surface-3 transition-colors">
              <svg class="w-[18px] h-[18px] theme-icon-moon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" /></svg>
              <svg class="w-[18px] h-[18px] theme-icon-sun hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
            </button>
            <div class="flex items-center gap-1 text-sm">
              <button data-lang="de" class="lang-btn px-1.5 py-0.5 rounded transition-colors text-text-tertiary hover:text-text-primary">DE</button>
              <span class="text-text-tertiary/40">|</span>
              <button data-lang="en" class="lang-btn px-1.5 py-0.5 rounded transition-colors font-semibold text-text-primary">EN</button>
            </div>
            <a href="#waitlist" data-i18n="nav.getStarted" class="inline-flex items-center justify-center px-4 py-2 text-sm font-semibold rounded-lg bg-primary text-white hover:bg-primary-light transition-colors">Join Waitlist</a>
          </div>

          <!-- Mobile -->
          <div class="md:hidden flex items-center gap-2">
            <button id="theme-toggle-mobile" type="button" aria-label="Toggle theme" class="p-2 rounded-lg text-text-secondary hover:text-text-primary hover:bg-surface-3 transition-colors">
              <svg class="w-[18px] h-[18px] theme-icon-moon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" /></svg>
              <svg class="w-[18px] h-[18px] theme-icon-sun hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
            </button>
            <label for="mobile-menu-toggle" class="flex flex-col justify-center items-center w-10 h-10 cursor-pointer gap-1.5">
              <span class="block w-5 h-0.5 bg-text-secondary transition-all"></span>
              <span class="block w-5 h-0.5 bg-text-secondary transition-all"></span>
              <span class="block w-5 h-0.5 bg-text-secondary transition-all"></span>
            </label>
          </div>

          <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />

          <div class="hidden peer-checked:flex absolute top-16 left-0 right-0 bg-surface-2/95 backdrop-blur-xl border-b border-border md:hidden flex-col p-6 gap-4">
            <a href="#features" data-i18n="nav.features" class="text-sm text-text-secondary hover:text-text-primary transition-colors py-2">Features</a>
            <a href="#how-it-works" data-i18n="nav.howItWorks" class="text-sm text-text-secondary hover:text-text-primary transition-colors py-2">How it Works</a>
            <a href="#pricing" data-i18n="nav.pricing" class="text-sm text-text-secondary hover:text-text-primary transition-colors py-2">Pricing</a>
            <div class="flex items-center gap-2 py-2 text-sm">
              <button data-lang="de" class="lang-btn px-2 py-1 rounded transition-colors text-text-tertiary hover:text-text-primary">DE</button>
              <span class="text-text-tertiary/40">|</span>
              <button data-lang="en" class="lang-btn px-2 py-1 rounded transition-colors font-semibold text-text-primary">EN</button>
            </div>
            <a href="#waitlist" data-i18n="nav.getStarted" class="inline-flex items-center justify-center px-4 py-2.5 text-sm font-semibold rounded-lg bg-primary text-white hover:bg-primary-light transition-colors mt-2">Join Waitlist</a>
          </div>
        </div>
      </div>
    </nav>

    <!-- ===== HERO ===== -->
    <section class="relative pt-28 pb-16 sm:pt-36 sm:pb-24 lg:pt-44 lg:pb-32">
      <div class="max-w-6xl mx-auto px-5 sm:px-6">
        <!-- Badge -->
        <div class="animate-fade-in mb-6">
          <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/8 border border-primary/15 text-primary text-sm font-medium">
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-primary" style="animation: pulse-glow 2s ease-in-out infinite;"></span>
            <span data-i18n="hero.kicker">Early access</span>
          </span>
        </div>

        <!-- Headline -->
        <h1 class="animate-fade-in-up text-3xl sm:text-[2.75rem] lg:text-[3.5rem] font-extrabold tracking-tight leading-[1.1] max-w-3xl mb-6">
          <span data-i18n="hero.headline">Campaign-ready image variants, without the tool chaos.</span>
        </h1>

        <!-- Subheadline -->
        <p class="animate-fade-in-up text-lg sm:text-xl text-text-secondary max-w-2xl leading-relaxed mb-8" style="animation-delay: 0.1s" data-i18n="hero.subheadline">
          LemonSpace is a visual workspace for small creative teams: brief, generate, compare, and export — your assets where you want them.
        </p>

        <!-- CTAs -->
        <div class="animate-fade-in-up flex flex-col sm:flex-row items-start gap-3 mb-16 sm:mb-20" style="animation-delay: 0.2s">
          <a href="#waitlist" class="inline-flex items-center justify-center px-6 py-3 text-base font-semibold rounded-xl bg-primary text-white hover:bg-primary-light transition-all shadow-lg shadow-primary/20 hover:shadow-primary/35 hover:-translate-y-0.5">
            <span data-i18n="nav.getStarted">Join Waitlist</span>
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
          <a href="#how-it-works" class="inline-flex items-center justify-center px-6 py-3 text-base font-semibold rounded-xl bg-surface-3 text-text-primary border border-border hover:border-border-light hover:bg-surface-4 transition-all">
            <span data-i18n="hero.ctaSecondary">See How it Works</span>
          </a>
        </div>

        <!-- Hero Visual: Canvas Mockup -->
        <div class="animate-fade-in-up relative max-w-4xl" style="animation-delay: 0.3s">
          <div class="window-mock">
            <div class="window-chrome">
              <div class="dot" style="background:#ef444480"></div>
              <div class="dot" style="background:#eab30880"></div>
              <div class="dot" style="background:#22c55e80"></div>
              <span class="ml-3 text-xs text-text-tertiary font-mono" data-i18n="visual.filename">campaign.lemon</span>
            </div>
            <div class="window-mock-body p-4 sm:p-6">
              <div class="grid grid-cols-3 gap-3 sm:gap-5">
                <!-- Node 1: Image Input -->
                <div class="rounded-lg border border-border bg-surface-2 p-3 sm:p-4">
                  <div class="w-full aspect-[4/3] rounded-md bg-gradient-to-br from-primary/15 to-accent/10 mb-2.5 flex items-center justify-center">
                    <svg class="w-7 h-7 sm:w-9 sm:h-9 text-primary/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" /></svg>
                  </div>
                  <div class="text-xs font-semibold text-text-primary" data-i18n="features.canvas.step1">Upload brief</div>
                  <div class="text-[10px] text-text-tertiary mt-0.5">input.jpg</div>
                </div>
                <!-- Node 2: Prompt -->
                <div class="rounded-lg border border-border bg-surface-2 p-3 sm:p-4">
                  <div class="w-full aspect-[4/3] rounded-md bg-gradient-to-br from-accent/12 to-accent-warm/8 mb-2.5 flex items-center justify-center">
                    <svg class="w-7 h-7 sm:w-9 sm:h-9 text-accent-warm/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" /></svg>
                  </div>
                  <div class="text-xs font-semibold text-text-primary" data-i18n="features.canvas.step2">Build prompt</div>
                  <div class="text-[10px] text-text-tertiary mt-0.5">"Summer vibes..."</div>
                </div>
                <!-- Node 3: AI Output -->
                <div class="rounded-lg border border-primary/30 bg-primary/5 p-3 sm:p-4">
                  <div class="w-full aspect-[4/3] rounded-md bg-gradient-to-br from-primary/18 via-accent/8 to-primary/12 mb-2.5 flex items-center justify-center relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-t from-primary/8 to-transparent"></div>
                    <svg class="w-7 h-7 sm:w-9 sm:h-9 text-primary/60 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>
                  </div>
                  <div class="text-xs font-semibold text-primary-light" data-i18n="features.canvas.step3">Generate variants</div>
                  <div class="text-[10px] text-text-tertiary mt-0.5">FLUX.2 → output</div>
                </div>
              </div>
              <!-- Status bar -->
              <div class="flex items-center justify-between mt-4 pt-3 border-t border-border">
                <div class="flex items-center gap-2">
                  <span class="inline-block w-2 h-2 rounded-full bg-primary" style="animation: pulse-glow 2s ease-in-out infinite;"></span>
                  <span class="text-xs text-text-tertiary">3 nodes connected</span>
                </div>
                <span class="text-xs text-text-tertiary font-mono">Ready to generate</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== THE ISSUE (soloterm-style) ===== -->
    <section class="py-16 sm:py-24 lg:py-32">
      <div class="max-w-6xl mx-auto px-5 sm:px-6">
        <!-- Label -->
        <div class="section-label mb-4">
          <svg class="w-4 h-4 text-text-tertiary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" /></svg>
          <span data-i18n="issue.label">The issue</span>
        </div>

        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight max-w-2xl mb-12 sm:mb-16" data-i18n="issue.headline">
          Your image workflow lives in eight browser tabs.
        </h2>

        <!-- Issue Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-5">
          <div class="issue-card">
            <h3 class="text-base font-semibold text-text-primary mb-2" data-i18n="issue.b1Title">Tab roulette</h3>
            <p class="text-sm text-text-secondary leading-relaxed" data-i18n="issue.b1">
              Something needs your attention. Is it tab three? Tab five? You're clicking through all eight trying to find the one that's screaming. By the time you find it, another tool has already timed out.
            </p>
          </div>
          <div class="issue-card">
            <h3 class="text-base font-semibold text-text-primary mb-2" data-i18n="issue.b2Title">No comparison</h3>
            <p class="text-sm text-text-secondary leading-relaxed" data-i18n="issue.b2">
              You generated twelve variants but they're scattered across folders, chats, and downloads. Comparing them means opening six windows side by side and hoping you don't lose track.
            </p>
          </div>
          <div class="issue-card">
            <h3 class="text-base font-semibold text-text-primary mb-2" data-i18n="issue.b3Title">Your brand, their server</h3>
            <p class="text-sm text-text-secondary leading-relaxed" data-i18n="issue.b3">
              Every prompt and asset lives on someone else's infrastructure. When confidentiality matters, parking brand assets in yet another SaaS is a tough sell.
            </p>
          </div>
        </div>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- ===== THE FIX ===== -->
    <section class="py-16 sm:py-24 lg:py-32">
      <div class="max-w-6xl mx-auto px-5 sm:px-6">
        <!-- Label -->
        <div class="section-label mb-4">
          <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <span class="section-label-accent" data-i18n="fix.label">The fix</span>
        </div>

        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight max-w-2xl mb-4" data-i18n="fix.headline">
          One canvas. Every variant. Full control.
        </h2>
        <p class="text-base sm:text-lg text-text-secondary max-w-2xl leading-relaxed" data-i18n="fix.subheadline">
          LemonSpace keeps everything on a single visual board — upload, prompt, generate, compare, and export from one place. No more juggling tools, no more scattered files.
        </p>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- ===== FEATURES (soloterm-style vertical blocks) ===== -->
    <section id="features" class="py-16 sm:py-24 lg:py-32">
      <div class="max-w-6xl mx-auto px-5 sm:px-6">
        <!-- Label -->
        <div class="section-label mb-4">
          <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <span class="section-label-accent" data-i18n="features.label">What LemonSpace actually does</span>
        </div>

        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight max-w-2xl mb-12 sm:mb-16">
          <span data-i18n="fix.headline">One canvas. Every variant. Full control.</span>
        </h2>

        <!-- Feature 1: Visual Canvas -->
        <div class="animate-on-scroll mb-10 sm:mb-14">
          <div class="feature-block">
            <div>
              <span class="text-xs font-semibold text-primary uppercase tracking-wider" data-i18n="features.canvas.tag">01 — Visual Canvas</span>
            </div>
            <div>
              <h3 class="text-xl sm:text-2xl font-bold text-text-primary mb-3" data-i18n="features.canvas.title">Visual Canvas</h3>
              <p class="text-base text-text-secondary leading-relaxed max-w-xl" data-i18n="features.canvas.desc">
                Your image workflow lives on a node-based canvas. Brief images, connect prompts, see generations, compare results, and export — all on one board. Drag nodes, connect them, and see the whole flow at a glance.
              </p>
            </div>
          </div>
        </div>

        <!-- Feature 2: Prompt Studio -->
        <div class="animate-on-scroll mb-10 sm:mb-14">
          <div class="feature-block">
            <div>
              <span class="text-xs font-semibold text-primary uppercase tracking-wider" data-i18n="features.prompt.tag">02 — Prompt Studio</span>
            </div>
            <div>
              <h3 class="text-xl sm:text-2xl font-bold text-text-primary mb-3" data-i18n="features.prompt.title">Prompt Studio</h3>
              <p class="text-base text-text-secondary leading-relaxed max-w-xl" data-i18n="features.prompt.desc">
                Stop writing prompts into a chat box. Prompt Studio gives you structured fields for brand, subject, style, format, and constraints. No more guessing what works — the brief builds the prompt for you.
              </p>
            </div>
          </div>
        </div>

        <!-- Feature 3: Comparison View -->
        <div class="animate-on-scroll mb-10 sm:mb-14">
          <div class="feature-block">
            <div>
              <span class="text-xs font-semibold text-primary uppercase tracking-wider" data-i18n="features.compare.tag">03 — Comparison View</span>
            </div>
            <div>
              <h3 class="text-xl sm:text-2xl font-bold text-text-primary mb-3" data-i18n="features.compare.title">Comparison View</h3>
              <p class="text-base text-text-secondary leading-relaxed max-w-xl" data-i18n="features.compare.desc">
                Line up variants side by side and pick the best one. See them all at once with confidence scores and star ratings. Flag the winner and send it straight to export — no screenshots scattered in a drive folder.
              </p>
            </div>
          </div>
        </div>

        <!-- Feature 4: Export Queue -->
        <div class="animate-on-scroll mb-10 sm:mb-14">
          <div class="feature-block">
            <div>
              <span class="text-xs font-semibold text-primary uppercase tracking-wider" data-i18n="features.export.tag">04 — Export Queue</span>
            </div>
            <div>
              <h3 class="text-xl sm:text-2xl font-bold text-text-primary mb-3" data-i18n="features.export.title">Export Queue</h3>
              <p class="text-base text-text-secondary leading-relaxed max-w-xl" data-i18n="features.export.desc">
                Batch-export campaign-ready assets in multiple formats and sizes. Web, social, print — name your presets and export them all with one click. No more opening Photoshop six times.
              </p>
            </div>
          </div>
        </div>

        <!-- Feature 5: Asset Library -->
        <div class="animate-on-scroll mb-10 sm:mb-14">
          <div class="feature-block">
            <div>
              <span class="text-xs font-semibold text-primary uppercase tracking-wider" data-i18n="features.library.tag">05 — Asset Library</span>
            </div>
            <div>
              <h3 class="text-xl sm:text-2xl font-bold text-text-primary mb-3" data-i18n="features.library.title">Asset Library</h3>
              <p class="text-base text-text-secondary leading-relaxed max-w-xl" data-i18n="features.library.desc">
                Upload and organize brand assets, reference images, and approved templates in one place. When someone on the team uploads a new reference, everyone sees it. No more scattered files in drive folders.
              </p>
            </div>
          </div>
        </div>

        <!-- Feature 6: Self-Hosted -->
        <div class="animate-on-scroll">
          <div class="feature-block">
            <div>
              <span class="text-xs font-semibold text-primary uppercase tracking-wider" data-i18n="features.selfhosted.tag">06 — Self-Hosted</span>
            </div>
            <div>
              <h3 class="text-xl sm:text-2xl font-bold text-text-primary mb-3" data-i18n="features.selfhosted.title">Self-Hosted</h3>
              <p class="text-base text-text-secondary leading-relaxed max-w-xl" data-i18n="features.selfhosted.desc">
                Run LemonSpace on your own infrastructure. Your brand assets never leave your server. Full control over data, deployment, and compliance. Docker, Kubernetes, or bare metal — you decide.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

