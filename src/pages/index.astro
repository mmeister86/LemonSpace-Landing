---
import LandingPage from './_landing.astro';
import de from '../i18n/de.json';
import en from '../i18n/en.json';

type Lang = 'de' | 'en';

function detectLocaleFromRequest(request: Request): Lang {
  const acceptLanguage = request.headers.get('accept-language') || '';
  const preferred = acceptLanguage
    .split(',')
    .map((item) => item.trim().toLowerCase())
    .find(Boolean);

  return preferred?.startsWith('en') ? 'en' : 'de';
}

const lang = detectLocaleFromRequest(Astro.request);
const copy = lang === 'en' ? en : de;
---

<LandingPage copy={copy} lang={lang} />
