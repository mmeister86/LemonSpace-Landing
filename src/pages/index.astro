    <!-- ===== SCROLL ANIMATION OBSERVER ===== -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.animate-on-scroll').forEach((el) => {
        observer.observe(el);
      });
    </script>

    <!-- ===== WAITLIST FORM ===== -->
    <script>
      (function() {
        var form = document.getElementById('waitlist-form');
        var msg = document.getElementById('waitlist-message');
        if (!form) return;

        form.addEventListener('submit', function(e) {
          e.preventDefault();
          var email = form.querySelector('input[type="email"]').value.trim();
          if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
            msg.textContent = form.querySelector('[data-i18n-placeholder="waitlist.emailPlaceholder"]') ?
              'Please enter a valid email address.' : 'Please enter a valid email address.';
            msg.className = 'mt-3 text-sm text-red-500';
            return;
          }
          // Check localStorage for duplicate
          if (localStorage.getItem('lemonspace-waitlist') === email) {
            msg.textContent = 'You already joined from this device.';
            msg.className = 'mt-3 text-sm text-text-tertiary';
            return;
          }
          // Simulate success
          localStorage.setItem('lemonspace-waitlist', email);
          msg.textContent = 'You are on the list. Thank you.';
          msg.className = 'mt-3 text-sm text-primary font-medium';
          form.querySelector('input[type="email"]').value = '';
        });
      })();
    </script>

    <!-- ===== i18n + THEME + LANGUAGE SWITCHER ===== -->
    <script define:vars={{ en, de }}>
      (function() {
        var translations = { en: en, de: de };
        var currentLang = 'en';

        function t(key, lang) {
          var keys = key.split('.');
          var val = translations[lang];
          for (var i = 0; i < keys.length; i++) {
            if (val == null) return key;
            val = val[keys[i]];
          }
          return val != null ? val : key;
        }

        function applyTranslations(lang) {
          currentLang = lang;
          document.documentElement.lang = lang;

          var els = document.querySelectorAll('[data-i18n]');
          for (var i = 0; i < els.length; i++) {
            var key = els[i].getAttribute('data-i18n');
            var val = t(key, lang);
            if (val !== key) els[i].textContent = val;
          }

          // Placeholders
          var phEls = document.querySelectorAll('[data-i18n-placeholder]');
          for (var i = 0; i < phEls.length; i++) {
            var key = phEls[i].getAttribute('data-i18n-placeholder');
            var val = t(key, lang);
            if (val !== key) phEls[i].placeholder = val;
          }

          var langBtns = document.querySelectorAll('.lang-btn');
          for (var i = 0; i < langBtns.length; i++) {
            var btnLang = langBtns[i].getAttribute('data-lang');
            if (btnLang === lang) {
              langBtns[i].classList.add('font-semibold', 'text-text-primary');
              langBtns[i].classList.remove('text-text-tertiary');
            } else {
              langBtns[i].classList.remove('font-semibold');
              langBtns[i].classList.add('text-text-tertiary');
              langBtns[i].classList.remove('text-text-primary');
            }
          }
        }

        function detectLanguage() {
          var stored = localStorage.getItem('lang');
          if (stored === 'de' || stored === 'en') return stored;
          var navLang = navigator.language || navigator.userLanguage || '';
          if (navLang.toLowerCase().startsWith('de')) return 'de';
          fetch('https://ipapi.co/json/', { signal: AbortSignal.timeout(3000) })
            .then(function(r) { return r.json(); })
            .then(function(data) {
              if (data && (data.country_code === 'DE' || data.country_code === 'AT' || data.country_code === 'CH')) {
                if (!localStorage.getItem('lang')) {
                  localStorage.setItem('lang', 'de');
                  applyTranslations('de');
                }
              }
            })
            .catch(function() {});
          return 'en';
        }

        function updateThemeIcons() {
          var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
          var moonIcons = document.querySelectorAll('.theme-icon-moon');
          var sunIcons = document.querySelectorAll('.theme-icon-sun');
          for (var i = 0; i < moonIcons.length; i++) { moonIcons[i].style.display = isDark ? 'none' : ''; }
          for (var i = 0; i < sunIcons.length; i++) { sunIcons[i].style.display = isDark ? '' : 'none'; }
        }

        function toggleTheme() {
          var html = document.documentElement;
          html.classList.add('theme-transitioning');
          var isDark = html.getAttribute('data-theme') === 'dark';
          if (isDark) {
            html.removeAttribute('data-theme');
            localStorage.setItem('theme', 'light');
          } else {
            html.setAttribute('data-theme', 'dark');
            localStorage.setItem('theme', 'dark');
          }
          updateThemeIcons();
          setTimeout(function() { html.classList.remove('theme-transitioning'); }, 350);
        }

        document.getElementById('theme-toggle').addEventListener('click', toggleTheme);
        document.getElementById('theme-toggle-mobile').addEventListener('click', toggleTheme);

        function switchLang(lang) {
          localStorage.setItem('lang', lang);
          applyTranslations(lang);
        }

        var langBtns = document.querySelectorAll('.lang-btn');
        for (var i = 0; i < langBtns.length; i++) {
          langBtns[i].addEventListener('click', function() {
            switchLang(this.getAttribute('data-lang'));
          });
        }

        updateThemeIcons();
        var detectedLang = detectLanguage();
        applyTranslations(detectedLang);
      })();
    </script>

