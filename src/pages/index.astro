    <!-- ===== SCROLL ANIMATION OBSERVER ===== -->
    <script>
      // Minimal IntersectionObserver for scroll animations
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.animate-on-scroll').forEach((el) => {
        observer.observe(el);
      });
    </script>

    <!-- ===== i18n + THEME + LANGUAGE SWITCHER ===== -->
    <script define:vars={{ en, de }}>
      (function() {
        var translations = { en: en, de: de };
        var currentLang = 'en';

        // --- i18n helper ---
        function t(key, lang) {
          var keys = key.split('.');
          var val = translations[lang];
          for (var i = 0; i < keys.length; i++) {
            if (val == null) return key;
            val = val[keys[i]];
          }
          return val != null ? val : key;
        }

        // --- Apply translations ---
        function applyTranslations(lang) {
          currentLang = lang;
          document.documentElement.lang = lang;

          // Simple text elements
          var els = document.querySelectorAll('[data-i18n]');
          for (var i = 0; i < els.length; i++) {
            var key = els[i].getAttribute('data-i18n');
            var val = t(key, lang);
            if (val !== key) {
              els[i].textContent = val;
            }
          }

          // List elements (pricing features)
          var listEls = document.querySelectorAll('[data-i18n-list]');
          for (var i = 0; i < listEls.length; i++) {
            var key = listEls[i].getAttribute('data-i18n-list');
            var arr = t(key, lang);
            if (Array.isArray(arr)) {
              var checkSvg = '<svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>';
              var html = '';
              for (var j = 0; j < arr.length; j++) {
                html += '<li class="flex items-start gap-3 text-sm text-text-secondary">' + checkSvg + '<span>' + arr[j] + '</span></li>';
              }
              listEls[i].innerHTML = html;
            }
          }

          // Update language switcher buttons
          var langBtns = document.querySelectorAll('.lang-btn');
          for (var i = 0; i < langBtns.length; i++) {
            var btnLang = langBtns[i].getAttribute('data-lang');
            if (btnLang === lang) {
              langBtns[i].classList.add('font-semibold', 'text-text-primary');
              langBtns[i].classList.remove('text-text-tertiary');
            } else {
              langBtns[i].classList.remove('font-semibold');
              langBtns[i].classList.add('text-text-tertiary');
              langBtns[i].classList.remove('text-text-primary');
            }
          }
        }

        // --- Language detection ---
        function detectLanguage() {
          var stored = localStorage.getItem('lang');
          if (stored === 'de' || stored === 'en') return stored;

          var navLang = navigator.language || navigator.userLanguage || '';
          if (navLang.toLowerCase().startsWith('de')) return 'de';

          // IP geolocation fallback (async, non-blocking)
          fetch('https://ipapi.co/json/', { signal: AbortSignal.timeout(3000) })
            .then(function(r) { return r.json(); })
            .then(function(data) {
              if (data && (data.country_code === 'DE' || data.country_code === 'AT' || data.country_code === 'CH')) {
                if (!localStorage.getItem('lang')) {
                  localStorage.setItem('lang', 'de');
                  applyTranslations('de');
                }
              }
            })
            .catch(function() { /* ignore — keep default */ });

          return 'en';
        }

        // --- Theme toggle ---
        function updateThemeIcons() {
          var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
          var moonIcons = document.querySelectorAll('.theme-icon-moon');
          var sunIcons = document.querySelectorAll('.theme-icon-sun');
          for (var i = 0; i < moonIcons.length; i++) {
            moonIcons[i].style.display = isDark ? 'none' : '';
          }
          for (var i = 0; i < sunIcons.length; i++) {
            sunIcons[i].style.display = isDark ? '' : 'none';
          }
        }

        function toggleTheme() {
          var html = document.documentElement;
          html.classList.add('theme-transitioning');
          var isDark = html.getAttribute('data-theme') === 'dark';
          if (isDark) {
            html.removeAttribute('data-theme');
            localStorage.setItem('theme', 'light');
          } else {
            html.setAttribute('data-theme', 'dark');
            localStorage.setItem('theme', 'dark');
          }
          updateThemeIcons();
          setTimeout(function() {
            html.classList.remove('theme-transitioning');
          }, 350);
        }

        // Bind theme toggles
        document.getElementById('theme-toggle').addEventListener('click', toggleTheme);
        document.getElementById('theme-toggle-mobile').addEventListener('click', toggleTheme);

        // --- Language switcher ---
        function switchLang(lang) {
          localStorage.setItem('lang', lang);
          applyTranslations(lang);
        }

        var langBtns = document.querySelectorAll('.lang-btn');
        for (var i = 0; i < langBtns.length; i++) {
          langBtns[i].addEventListener('click', function() {
            switchLang(this.getAttribute('data-lang'));
          });
        }

        // --- Initialize ---
        updateThemeIcons();
        var detectedLang = detectLanguage();
        applyTranslations(detectedLang);
      })();
    </script>

  </body>
</html>
