---
interface Props {
  copy: any;
  instance: string;
  lang: 'de' | 'en';
  isPrimary?: boolean;
  initialMessage?: string;
  initialMessageClass?: string;
}

const {
  copy,
  instance,
  lang,
  isPrimary = false,
  initialMessage = '',
  initialMessageClass = 'form-msg hidden',
} = Astro.props as Props;

const emailId = `waitlist-email-${instance}`;
const companyId = `waitlist-company-${instance}`;
---

<form
  data-waitlist-form
  data-waitlist-primary={isPrimary ? 'true' : 'false'}
  method="POST"
  action="/api/waitlist"
  class="form"
  novalidate
  data-waitlist-instance={instance}
>
  <label for={emailId}>{copy.emailLabel}</label>
  <div class="row">
    <input
      id={emailId}
      name="email"
      type="email"
      required
      autocomplete="email"
      placeholder={copy.emailPlaceholder}
    />
    <input data-waitlist-lang type="hidden" name="lang" value={lang} />
    <div class="hidden" aria-hidden="true">
      <label for={companyId}>Company</label>
      <input id={companyId} type="text" name="company" tabindex="-1" autocomplete="off" />
    </div>
    <button data-waitlist-submit type="submit">
      <span data-waitlist-submit-label>{copy.submit}</span>
      <svg style="margin-left: 4px;" width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"></path></svg>
    </button>
  </div>
  <p class="note">{copy.privacyNote}</p>
  <div data-waitlist-message class={initialMessageClass} aria-live="polite">{initialMessage}</div>
</form>
