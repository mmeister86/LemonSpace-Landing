---
interface Props {
  copy: any;
}

const { copy } = Astro.props as Props;
---

<!-- ═════════ MANIFESTO / FIX ═════════ -->
<section class="manifesto">
  <div class="wrap">
    <span class="eyebrow">{copy.label}</span>
    <h2 style="margin-top: 22px;">
      {copy.headline.before} <em>{copy.headline.firstEm}</em> {copy.headline.middle} <em>{copy.headline.secondEm}</em>
    </h2>
    <p class="lede" style="text-align: center;">
      {copy.subheadline}
    </p>
  </div>
</section>
