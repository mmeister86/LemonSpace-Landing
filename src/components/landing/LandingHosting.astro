---
interface Props {
  copy: any;
}

const { copy } = Astro.props as Props;
---

<!-- ═════════ SELF-HOSTED ═════════ -->
<section class="section-pad alt-bg-deep" id="hosting">
  <div class="wrap">
    <div class="host">
      <div>
        <span class="eyebrow">{copy.label}</span>
        <h2 class="section-h" style="margin-top: 18px;">{copy.headline}</h2>
        <p class="lede" style="margin-top: 24px;">
          {copy.subheadline}
        </p>
        <div class="host-bullets">
          {copy.bullets.map((bullet) => (
            <div>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M3 8.5l3 3 7-7"></path></svg>
              <div><b>{bullet.title}</b> <span style="color: color-mix(in srgb, var(--bg) 55%, transparent);">{bullet.desc}</span></div>
            </div>
          ))}
        </div>
      </div>

      <div class="terminal">
        <div class="terminal-bar">
          <span></span><span></span><span></span>
          <span class="name">~/lemonspace</span>
        </div>
        <div class="terminal-body">
<span class="d">$</span> <span class="p">git clone</span> github.com/lemonspace/<span class="c">lemonspace.git</span>
<span class="d">$</span> <span class="p">cp</span> .env.example .env
<span class="d">$</span> <span class="p">docker compose up</span> -d
<br>
<span class="d">→</span> next.js               <span class="ok">ready</span>  :3000
<span class="d">→</span> convex (self-hosted)  <span class="ok">ready</span>  :3210
<span class="d">→</span> redis                 <span class="ok">ready</span>  :6379
<span class="d">→</span> rembg / esrgan        <span class="ok">ready</span>
<br>
<span class="d">✓</span> {copy.terminal.readyPrefix} <span class="c">localhost:3000</span>
        </div>
      </div>
    </div>
  </div>
</section>
