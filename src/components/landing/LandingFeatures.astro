---
interface Props {
  copy: any;
}

const { copy } = Astro.props as Props;
---

<!-- ═════════ FEATURES ═════════ -->
<section class="section-pad" id="features">
  <div class="wrap">
    <span class="eyebrow muted">{copy.label}</span>
    <h2 class="section-h" style="margin-top: 18px; max-width: 22ch;">
      {copy.headline}
    </h2>

    <div class="features-grid">
      <div class="feature">
        <div class="num">{copy.items[0].num} <span></span> {copy.items[0].tag}</div>
        <h3>{copy.items[0].title}</h3>
        <p>{copy.items[0].desc}</p>
        <div class="vis vis-canvas">
          <div class="row"><div class="blob b1"></div><div class="arrow"></div><div class="blob b2"></div><div class="arrow"></div><div class="blob b5"></div></div>
          <div class="row"><div class="blob b3"></div><div class="arrow"></div><div class="blob b4"></div><div class="arrow"></div><div class="blob b1"></div></div>
          <div class="row"><div class="blob b4"></div><div class="arrow"></div><div class="blob b3"></div></div>
        </div>
      </div>

      <div class="feature">
        <div class="num">{copy.items[1].num} <span></span> {copy.items[1].tag}</div>
        <h3>{copy.items[1].title}</h3>
        <p>{copy.items[1].desc}</p>
        <div class="vis vis-lib">
          <div class="tile"></div><div class="tile"></div><div class="tile"></div><div class="tile"></div>
          <div class="tile"></div><div class="tile"></div><div class="tile"></div><div class="tile"></div>
        </div>
      </div>

      <div class="feature">
        <div class="num">{copy.items[2].num} <span></span> {copy.items[2].tag}</div>
        <h3>{copy.items[2].title}</h3>
        <p>{copy.items[2].desc}</p>
        <span class="free">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M2 5.5l2 2 4-4"></path></svg>
          {copy.items[2].badge}
        </span>
        <div class="vis vis-stack" style="margin-top: 22px;">
          {copy.items[2].layers.map((layer) => (
            <div class="layer"><span>{layer.name}</span><span class="tag">{layer.value}</span></div>
          ))}
        </div>
      </div>

      <div class="feature">
        <div class="num">{copy.items[3].num} <span></span> {copy.items[3].tag}</div>
        <h3>{copy.items[3].title}</h3>
        <p>{copy.items[3].desc}</p>
        <div class="vis vis-agent">
          {copy.items[3].rows.map((row, index) => (
            <div class="row">
              <span class="num" style={index === 0 ? 'background: var(--primary-soft); color: var(--primary);' : undefined}>{index + 1}</span>
              {row.label}
              <span class="bar"><i style={`width: ${row.progress}%;`}></i></span>
              {row.done && <span class="check">✓</span>}
            </div>
          ))}
        </div>
      </div>

      <div class="feature">
        <div class="num">{copy.items[4].num} <span></span> {copy.items[4].tag}</div>
        <h3>{copy.items[4].title}</h3>
        <p>{copy.items[4].desc}</p>
        <div class="vis vis-compare"></div>
      </div>

      <div class="feature">
        <div class="num">{copy.items[5].num} <span></span> {copy.items[5].tag}</div>
        <h3>{copy.items[5].title}</h3>
        <p>{copy.items[5].desc}</p>
        <div class="vis vis-ai">
          <div class="t"></div><div class="t"></div><div class="t"></div>
          <div class="t"></div><div class="t"></div><div class="t"></div>
        </div>
      </div>
    </div>
  </div>
</section>
