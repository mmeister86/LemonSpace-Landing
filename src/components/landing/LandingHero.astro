---
interface Props {
  copy: any;
}

const { copy } = Astro.props as Props;
---

<!-- ═════════ HERO ═════════ -->
<section class="hero">
  <div class="wrap" style="margin-top: 40px;">
    <div class="hero-grid">
      <div>
        <span class="eyebrow">{copy.kicker}</span>
        <h1 class="display" style="margin-top: 22px;">
          {copy.headline.before} <em>{copy.headline.em}</em>{copy.headline.after}
        </h1>
        <p class="lede" style="margin-top: 28px;">
          {copy.subheadline}
        </p>
        <div class="hero-cta">
          <a href="#waitlist" class="btn btn-primary">
            {copy.ctaPrimary}
            <svg
              class="btn-arrow"
              width="14"
              height="14"
              viewBox="0 0 14 14"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              ><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"></path></svg
            >
          </a>
          <a href="#how" class="btn btn-ghost">
            {copy.ctaSecondary}
            <svg
              class="btn-arrow"
              width="14"
              height="14"
              viewBox="0 0 14 14"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              ><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"></path></svg
            >
          </a>
        </div>
        <div class="hero-meta">
          {copy.meta.map((item) => <span><i class="dot"></i> {item}</span>)}
        </div>
        <div class="hero-proof" aria-label={copy.proofLabel}>
          {copy.proof.map((item) => (
            <div>
              <b>{item.title}</b>
              <span>{item.desc}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Hero canvas -->
      <div style="position: relative;">
        <div class="canvas-frame">
          <div class="canvas-chrome">
            <span class="lights"><span></span><span></span><span></span></span>
            <span style="color: var(--ink-2);">{copy.canvas.filename}</span>
            <span class="crumb">{copy.canvas.crumb}</span>
          </div>
          <div class="canvas-stage">
            <svg class="wires" viewBox="0 0 600 480" preserveAspectRatio="none">
              <defs>
                <path id="wire1" d="M 215 95 C 270 95, 280 130, 320 130"></path>
                <path id="wire2" d="M 215 350 C 270 350, 280 200, 320 200"
                ></path>
                <path id="wire3" d="M 440 165 C 480 165, 490 290, 540 290"
                ></path>
                <marker
                  id="arrow"
                  viewBox="0 0 10 10"
                  refX="9"
                  refY="5"
                  markerWidth="6"
                  markerHeight="6"
                  orient="auto"
                >
                  <path d="M0,0 L10,5 L0,10 Z" fill="var(--rule-2)"></path>
                </marker>
              </defs>
              <use
                href="#wire1"
                stroke="var(--rule-2)"
                stroke-width="1.5"
                fill="none"
                stroke-dasharray="3 4"
                marker-end="url(#arrow)"></use>
              <use
                href="#wire2"
                stroke="var(--rule-2)"
                stroke-width="1.5"
                fill="none"
                stroke-dasharray="3 4"
                marker-end="url(#arrow)"></use>
              <use
                href="#wire3"
                stroke="var(--rule-2)"
                stroke-width="1.5"
                fill="none"
                stroke-dasharray="3 4"
                marker-end="url(#arrow)"></use>
              <circle r="3" fill="var(--primary-2)"
                ><animateMotion dur="3.4s" repeatCount="indefinite"
                  ><mpath href="#wire1"></mpath></animateMotion
                ></circle
              >
              <circle r="3" fill="var(--primary-2)"
                ><animateMotion dur="3.6s" repeatCount="indefinite" begin="1.1s"
                  ><mpath href="#wire2"></mpath></animateMotion
                ></circle
              >
              <circle r="3" fill="var(--accent-warm)"
                ><animateMotion dur="3.2s" repeatCount="indefinite" begin="0.5s"
                  ><mpath href="#wire3"></mpath></animateMotion
                ></circle
              >
            </svg>

            <!-- Node 1: Image -->
            <div class="node n-img">
              <div class="node-head">
                <i class="dot"></i><span class="pill">{copy.canvas.imageLabel}</span><span
                  style="margin-left:auto;">{copy.canvas.imageFile}</span
                >
              </div>
              <div class="body">
                <div class="ph"></div>
                <div class="label"><span>2400×1600</span><span>v3</span></div>
              </div>
            </div>

            <!-- Node 2: Prompt -->
            <div class="node n-prompt">
              <div class="node-head">
                <i class="dot" style="background: var(--accent-warm);"></i><span
                  class="pill">Prompt</span
                ><span style="margin-left:auto;">brief.md</span>
              </div>
              <div class="body">
                <div class="text" set:html={copy.canvas.promptText}></div>
                <div class="params">
                  {copy.canvas.promptChips.map((chip, index) => (
                    <span class:list={['chip', { on: index === 0 }]}>{chip}</span>
                  ))}
                </div>
              </div>
            </div>

            <!-- Node 3: AI image -->
            <div class="node n-ai">
              <div class="node-head">
                <i class="dot"></i><span class="pill">{copy.canvas.aiLabel}</span><span
                  style="margin-left:auto;">{copy.canvas.aiOutputs}</span
                >
              </div>
              <div class="grid">
                <div class="tile"></div><div class="tile"></div><div
                  class="tile"
                >
                </div><div class="tile"></div>
              </div>
              <div class="meta">
                <span>{copy.canvas.aiSelected}</span><span set:html={copy.canvas.aiCredits}></span>
              </div>
            </div>

            <!-- Node 4: Compare -->
            <div class="node n-cmp">
              <div class="node-head">
                <i class="dot" style="background: var(--ink-2);"></i><span
                  class="pill">Compare</span
                ><span style="margin-left:auto;">A vs. B</span>
              </div>
              <div class="compare"><div class="handle"></div></div>
              <div class="meta">
                <span>{copy.canvas.compareLabel}</span>
                <span class="ok">
                  <svg
                    width="10"
                    height="10"
                    viewBox="0 0 10 10"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"><path d="M2 5.5l2 2 4-4"></path></svg
                  >
                  {copy.canvas.exportReady}
                </span>
              </div>
            </div>
          </div>
        </div>
        <div class="credit-chip" set:html={copy.canvas.creditChip}></div>
      </div>
    </div>

    <!-- Logo strip -->
    <div class="logos">
      <div class="logos-inner">
        <span>{copy.stack.label}</span>
        {copy.stack.items.map((item) => <span class="logos-pill">{item}</span>)}
      </div>
    </div>
  </div>
</section>

<!-- ═════════ STRIP / SCROLLER ═════════ -->
<div class="strip" aria-hidden="true">
  <div class="strip-track">
    {[...copy.strip, ...copy.strip].map((item) => (
      <>
        <span>{item}</span><span class="dot">●</span>
      </>
    ))}
  </div>
</div>
