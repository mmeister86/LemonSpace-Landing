---
interface Props {
  copy: any;
}

const { copy } = Astro.props as Props;
---

<!-- ═════════ PROBLEM ═════════ -->
<section class="section-pad alt-bg">
  <div class="wrap">
    <span class="eyebrow muted">{copy.label}</span>
    <h2 class="section-h" style="margin-top: 18px;">
      {copy.headline.before} <em style="color: #c0521b; font-style: normal;">{copy.headline.em}</em>
    </h2>

    <div class="problem-grid" style="margin-top: 56px;">
      <div class="tabs-mock">
        <div class="tabs-bar">
          {copy.tabs.map((tab) => (
            <div class:list={['tab', tab.state]}>
              {tab.label}
              {tab.close && <span class="x">×</span>}
            </div>
          ))}
        </div>
        <div class="tabs-content">
          {copy.events.map((event) => (
            <div class="row" style={event.style || undefined}>
              <b>{event.time}</b> &nbsp; <span set:html={event.text}></span>
            </div>
          ))}
        </div>
      </div>

      <div class="pain-list">
        {copy.items.map((item, index) => (
          <div class="pain-item">
            <span class="pain-num">{String(index + 1).padStart(2, '0')}</span>
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
