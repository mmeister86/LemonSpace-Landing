---
import WaitlistSignup from '../WaitlistSignup.astro';

interface Props {
  copy: any;
  lang: 'de' | 'en';
  initialMessage?: string;
  initialMessageClass?: string;
}

const { copy, lang, initialMessage = '', initialMessageClass = 'form-msg hidden' } = Astro.props as Props;
---

<!-- ═════════ WAITLIST ═════════ -->
<section class="section-pad alt-bg" id="waitlist">
  <div class="wrap">
    <div class="waitlist">
      <div>
        <span class="eyebrow">{copy.label}</span>
        <h2 class="section-h" style="margin-top: 18px;">{copy.ctaHeadline}</h2>
        <p class="lede" style="margin-top: 22px;">
          {copy.ctaSub}
        </p>
      </div>
      <WaitlistSignup
        copy={copy}
        lang={lang}
        instance="primary"
        isPrimary={true}
        initialMessage={initialMessage}
        initialMessageClass={initialMessageClass}
      />
    </div>
  </div>
</section>
