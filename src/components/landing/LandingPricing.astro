      </div>
      <div class="price">
        <h3>Starter</h3>
        <div class="price-val">€8<small>/Monat</small></div>
        <div class="credits">400 Credits / Monat</div>
        <ul>
          <li>Premium-Modelle</li>
          <li>Mehrere Workspaces</li>
          <li>E-Mail-Support</li>
          <li>Top-Up jederzeit</li>
        </ul>
        <button type="button" class="price-cta" disabled aria-disabled="true">Noch nicht verfügbar</button>
      </div>
      <div class="price popular">
        <h3>Pro</h3>
        <div class="price-val">€59<small>/Monat</small></div>
        <div class="credits">3.300 Credits / Monat</div>
