      <div class="price">
        <h3>Max</h3>
        <div class="price-val">€119<small>/Monat</small></div>
        <div class="credits">6.700 Credits / Monat</div>
        <ul>
          <li>Alles aus Pro</li>
          <li>API-Zugang</li>
          <li>Dedizierter Support</li>
          <li>Höchste Concurrency</li>
        </ul>
        <button type="button" class="price-cta" disabled aria-disabled="true">Noch nicht verfügbar</button>
