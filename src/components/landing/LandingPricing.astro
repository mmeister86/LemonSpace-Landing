---
interface Props {
  copy: any;
}

const { copy } = Astro.props as Props;
---

<!-- ═════════ PRICING ═════════ -->
<section class="section-pad" id="pricing">
  <div class="wrap">
    <span class="eyebrow muted">{copy.label}</span>
    <h2 class="section-h" style="margin-top: 18px; max-width: 20ch;">
      {copy.headline}
    </h2>
    <div class="pricing-info" set:html={copy.info}></div>

    <div class="price-grid">
      {copy.plans.map((plan) => (
        <div class:list={['price', { popular: plan.popular }]}>
          <h3>{plan.title}</h3>
          <div class="price-val">{plan.price}<small>{plan.interval}</small></div>
          <div class="credits">{plan.credits}</div>
          <ul>
            {plan.features.map((feature) => <li>{feature}</li>)}
          </ul>
          <button type="button" class="price-cta" disabled aria-disabled="true">{copy.unavailable}</button>
        </div>
      ))}
    </div>
  </div>
</section>
