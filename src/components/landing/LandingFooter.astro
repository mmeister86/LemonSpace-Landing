---
interface Props {
  copy: any;
}

const { copy } = Astro.props as Props;
---

<!-- ═════════ FOOTER ═════════ -->
<footer>
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <a href="#" class="brand"><img class="brand-logo" src="/logos/lemonspace-logo-v2-primary-rgb.svg" alt="" width="156" height="30" /><span>LemonSpace</span></a>
        <p class="footer-tag">{copy.tagline}</p>
      </div>
      {copy.groups.map((group) => (
        <div>
          <h4>{group.title}</h4>
          <ul>
            {group.links.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
          </ul>
        </div>
      ))}
    </div>
    <div class="footer-bottom">
      <span>{copy.copyright}</span>
      <span>{copy.license}</span>
    </div>
  </div>
</footer>
